# Local development environment for kolss-platform-api
# Copy to .env and fill values. For local without Turnstile/S3 set BOTCHECK_DISABLED=true.

HTTP_ADDR=:8080
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://127.0.0.1:4200,http://127.0.0.1:4201,https://crm.kolss.eu
BODY_LIMIT_BYTES=65536
RATE_LIMIT_PER_MINUTE=30
SHUTDOWN_TIMEOUT_SECONDS=10
PUBLIC_SITE_FORMS_ENABLED=false
NOTIFICATION_DISPATCHER_ENABLED=true
NOTIFICATION_SWEEP_INTERVAL_MINUTES=60
NOTIFICATION_BATCH_SIZE=20
# Daily Telegram lead report: enable and local hour (0-23) to send
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR_LOCAL=9

SUPABASE_URL=https://fpqolqiivzokwpmymqsr.supabase.co
SUPABASE_JWKS_URL=https://fpqolqiivzokwpmymqsr.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://fpqolqiivzokwpmymqsr.supabase.co/auth/v1
# Required for create/update/deactivate/delete users (Supabase service_role / secret key).
# SUPABASE_SERVICE_ROLE_KEY is accepted as a fallback name.
SUPABASE_SECRET_KEY=

META_INTEGRATION_ENABLED=false
META_GRAPH_API_VERSION=v25.0
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_PAGE_ID_KYIV=
META_PAGE_ACCESS_TOKEN_KYIV=
META_PAGE_ID_WARSAW=
META_PAGE_ACCESS_TOKEN_WARSAW=
# RFC3339 UTC timestamp. Reconciliation never imports leads older than this cutoff.
META_INGEST_AFTER=
META_RECONCILIATION_INTERVAL_MINUTES=15
META_RECONCILIATION_LOOKBACK_HOURS=72
META_ALERT_TELEGRAM_CHAT_ID=

BOTCHECK_DISABLED=true
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1
TURNSTILE_EXPECTED_ACTION=lead_submission

SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=eu-central-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

CRM_SITE_URL_PUBLIC=https://crm.kolss.eu
DEEPL_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_KYIV=
TELEGRAM_CHAT_ID_KYIV=
# Comma-separated secondary Kyiv chat IDs. Production: -1002833157899
TELEGRAM_ADDITIONAL_CHAT_IDS_KYIV=
SLACK_BOT_TOKEN_WARSAW=
SLACK_CHANNEL_ID_WARSAW=
