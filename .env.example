# Local development environment for kolss-platform-api
# Copy to .env and fill values. For local without Turnstile/S3 set BOTCHECK_DISABLED=true.

HTTP_ADDR=:8080
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://127.0.0.1:4200,http://127.0.0.1:4201
BODY_LIMIT_BYTES=65536
COMPLETE_BODY_LIMIT_BYTES=16384
RATE_LIMIT_PER_MINUTE=30
SHUTDOWN_TIMEOUT_SECONDS=10

SUBMISSION_TOKEN_PEPPER=local-dev-pepper-change-me
SUBMISSION_TTL_MINUTES=60
PRESIGN_TTL_MINUTES=10
STORAGE_QUARANTINE_BUCKET=lead-uploads-quarantine

BOTCHECK_DISABLED=true
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1
TURNSTILE_EXPECTED_ACTION=lead_submission

SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=eu-central-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

CRM_SITE_URL_PUBLIC=https://crm.kolss.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_KYIV=
TELEGRAM_BOT_TOKEN_WARSAW=
TELEGRAM_CHAT_ID_KYIV=
TELEGRAM_CHAT_ID_WARSAW=
SLACK_WEBHOOK_URL_KYIV=
SLACK_WEBHOOK_URL_WARSAW=

# Worker
WORKER_HEALTH_ADDR=:8081
WORKER_CLEANUP_INTERVAL_SECONDS=60
WORKER_SCAN_INTERVAL_SECONDS=15
WORKER_NOTIFY_INTERVAL_SECONDS=10
